<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/color_outline"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Profile photo -->
        <ImageView
            android:id="@+id/ivProfilePhoto"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_person_placeholder"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_circle_outline"
            android:clipToOutline="true"
            android:contentDescription="Worker profile photo" />

        <!-- Worker info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <!-- Name -->
            <TextView
                android:id="@+id/tvWorkerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Skill badge chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipSkillBadge"
                style="@style/Widget.MaterialComponents.Chip.Entry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:clickable="false"
                android:focusable="false"
                app:chipBackgroundColor="@color/color_primary"
                app:chipIconVisible="false"
                app:closeIconVisible="false"
                android:textColor="@color/color_on_primary"
                android:textSize="12sp" />

            <!-- Daily rate and distance row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/tvDailyRate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_secondary" />

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_hint" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
