<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <!-- Main content: filters + results -->
    <LinearLayout
        android:id="@+id/layoutContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="8dp"
            android:text="Find Workers"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:fontFamily="sans-serif-medium" />

        <!-- Skill filter label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="@string/label_search_skill"
            android:textSize="14sp"
            android:textColor="@color/color_text_secondary" />

        <!-- Skill filter ChipGroup (single selection) -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupSkills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="4dp"
            app:singleSelection="true"
            app:selectionRequired="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSkillPainting"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skill_painting"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSkillTiling"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skill_tiling"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSkillPlumbing"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skill_plumbing"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSkillElectrical"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skill_electrical"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSkillGardening"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skill_gardening"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSkillCarpentry"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skill_carpentry"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Radius filter label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="@string/label_radius"
            android:textSize="14sp"
            android:textColor="@color/color_text_secondary" />

        <!-- Radius filter ChipGroup (single selection, default 5 km) -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupRadius"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="8dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip1km"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/radius_1km"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip2km"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/radius_2km"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip5km"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/radius_5km"
                android:checked="true"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip10km"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/radius_10km"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_outline" />

        <!-- ProgressBar (shown while loading) -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:indeterminateTint="@color/color_primary"
            android:visibility="gone" />

        <!-- Error TextView -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:textColor="@color/color_error"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Empty state TextView -->
        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:text="@string/msg_no_workers"
            android:textColor="@color/color_text_secondary"
            android:textSize="16sp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Worker results RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvWorkers"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Location permission denied layout (shown when permission is denied) -->
    <LinearLayout
        android:id="@+id/layoutLocationDenied"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvLocationDeniedMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/msg_location_required"
            android:textSize="16sp"
            android:textColor="@color/color_text_secondary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenSettings"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/btn_open_settings"
            android:textColor="@color/color_on_primary"
            android:backgroundTint="@color/color_primary"
            android:paddingHorizontal="32dp"
            android:paddingVertical="12dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
