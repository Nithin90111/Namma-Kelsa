<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="100dp"
    android:layout_height="100dp"
    android:layout_marginEnd="8dp">

    <!-- Gallery photo ImageView (100dp x 100dp) -->
    <ImageView
        android:id="@+id/ivGalleryPhoto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="Gallery photo"
        android:background="@color/color_outline" />

    <!-- Delete (×) button overlay in top-right corner -->
    <ImageButton
        android:id="@+id/btnDeletePhoto"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="top|end"
        android:layout_margin="4dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="@color/color_secondary"
        android:padding="2dp"
        android:contentDescription="Delete photo"
        android:tint="@color/color_on_primary" />

</FrameLayout>
