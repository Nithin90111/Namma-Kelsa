<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="40dp"
        android:paddingBottom="32dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Profile"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:fontFamily="sans-serif-medium"
            android:gravity="center" />

        <!-- Profile photo section -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_gravity="center_horizontal">

            <!-- Profile photo ImageView (circular, 100dp, clickable) -->
            <ImageView
                android:id="@+id/ivProfilePhoto"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_person_placeholder"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_outline"
                android:clipToOutline="true"
                android:contentDescription="Profile photo"
                android:clickable="true"
                android:focusable="true" />

            <!-- Camera icon overlay -->
            <ImageView
                android:id="@+id/ivCameraOverlay"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="bottom|end"
                android:src="@android:drawable/ic_menu_camera"
                android:background="@color/color_primary"
                android:padding="4dp"
                android:contentDescription="Change photo"
                android:clickable="false"
                android:focusable="false" />

        </FrameLayout>

        <!-- Name input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilName"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/hint_name"
            app:boxStrokeColor="@color/color_primary"
            app:hintTextColor="@color/color_text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName|textCapWords"
                android:maxLines="1"
                android:imeOptions="actionNext"
                android:textColor="@color/color_text_primary"
                android:textSize="16sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Name error -->
        <TextView
            android:id="@+id/tvNameError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="4dp"
            android:textColor="@color/color_error"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Skill selection label -->
        <TextView
            android:id="@+id/tvSkillLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/label_skill"
            android:textSize="14sp"
            android:textColor="@color/color_text_secondary" />

        <!-- Skill ChipGroup (single selection, 6 chips) -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupSkills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="true"
            app:selectionRequired="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPainting"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skill_painting"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTiling"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skill_tiling"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPlumbing"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skill_plumbing"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipElectrical"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skill_electrical"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipGardening"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skill_gardening"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCarpentry"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/skill_carpentry"
                app:chipBackgroundColor="@color/color_surface"
                app:checkedIconVisible="false" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Skill error -->
        <TextView
            android:id="@+id/tvSkillError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="4dp"
            android:textColor="@color/color_error"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Daily rate input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDailyRate"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="@string/label_daily_rate"
            app:boxStrokeColor="@color/color_primary"
            app:hintTextColor="@color/color_text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDailyRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLines="1"
                android:imeOptions="actionDone"
                android:textColor="@color/color_text_primary"
                android:textSize="16sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Daily rate error -->
        <TextView
            android:id="@+id/tvRateError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="4dp"
            android:textColor="@color/color_error"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Update Location button (outlined) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpdateLocation"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Update Location"
            android:textSize="14sp"
            app:strokeColor="@color/color_primary"
            android:textColor="@color/color_primary" />

        <!-- Gallery section title -->
        <TextView
            android:id="@+id/tvGalleryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Work Gallery"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary" />

        <!-- Gallery horizontal container (up to 3 photos) -->
        <LinearLayout
            android:id="@+id/galleryContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="start" />

        <!-- Add Photo button (visible only when gallery < 3 photos) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddPhoto"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="+ Add Photo"
            android:textSize="14sp"
            app:strokeColor="@color/color_primary"
            android:textColor="@color/color_primary"
            android:visibility="visible" />

        <!-- Save Changes button (full width, orange) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveChanges"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Save Changes"
            android:textSize="16sp"
            android:textColor="@color/color_on_primary"
            android:backgroundTint="@color/color_primary"
            android:paddingVertical="14dp" />

        <!-- Progress bar (initially GONE) -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:indeterminateTint="@color/color_primary"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
